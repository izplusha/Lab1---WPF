<Window x:Class="Lab1.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:system="clr-namespace:System;assembly=mscorlib"
        mc:Ignorable="d"
        Title="Habitica — дневник привычек"
        Height="760" Width="1180"
        MinWidth="980" MinHeight="640"
        FontFamily="{StaticResource UiFont}"
        Background="{DynamicResource WindowBackground}">

    <DockPanel>

        <!-- ВЕРХНЯЯ ШАПКА: меню + панель инструментов в одной полосе -->
        <Border DockPanel.Dock="Top"
                Background="{DynamicResource HeaderBackground}"
                Padding="18,8">
            <DockPanel>
                <StackPanel Orientation="Horizontal" DockPanel.Dock="Left">
                    <TextBlock Text="✦"
                               Foreground="{DynamicResource Accent}"
                               FontSize="22" VerticalAlignment="Center"
                               Margin="0,0,10,0"/>
                    <TextBlock Text="Habitica"
                               Foreground="{DynamicResource HeaderForeground}"
                               FontSize="18" FontWeight="SemiBold"
                               VerticalAlignment="Center"/>
                    <TextBlock Text="дневник привычек"
                               Foreground="{DynamicResource TextSecondary}"
                               FontSize="12" VerticalAlignment="Center"
                               Margin="10,4,0,0"/>
                </StackPanel>

                <Menu DockPanel.Dock="Left"
                      Background="Transparent"
                      Foreground="{DynamicResource HeaderForeground}"
                      Margin="32,0,0,0"
                      FontSize="13">
                    <MenuItem Header="Файл" Foreground="{DynamicResource HeaderForeground}">
                        <MenuItem Header="Сохранить" Click="MenuSave_Click"/>
                        <MenuItem Header="Загрузить" Click="MenuLoad_Click"/>
                        <Separator/>
                        <MenuItem Header="Выход" Click="MenuExit_Click"/>
                    </MenuItem>
                    <MenuItem Header="Правка" Foreground="{DynamicResource HeaderForeground}">
                        <MenuItem Header="Копировать" Click="MenuCopy_Click"/>
                        <MenuItem Header="Вставить" Click="MenuPaste_Click"/>
                    </MenuItem>
                    <MenuItem Header="Вид" Foreground="{DynamicResource HeaderForeground}">
                        <MenuItem Header="Тёмная тема" Click="MenuDarkTheme_Click"/>
                        <MenuItem Header="Светлая тема" Click="MenuLightTheme_Click"/>
                    </MenuItem>
                </Menu>

                <StackPanel Orientation="Horizontal"
                            DockPanel.Dock="Right"
                            HorizontalAlignment="Right">
                    <Button Content="Сохранить" Click="MenuSave_Click"
                            ToolTip="Сохранить профиль"
                            Margin="0,0,8,0"/>
                    <Button Style="{StaticResource GhostButton}"
                            Content="Загрузить" Click="MenuLoad_Click"
                            Foreground="{DynamicResource HeaderForeground}"
                            ToolTip="Загрузить данные"
                            Margin="0,0,8,0"/>
                    <ToggleButton x:Name="toggleEditMode"
                                  Checked="ToggleEditMode_Checked"
                                  Unchecked="ToggleEditMode_Unchecked"
                                  Content="◧ Боковая панель"
                                  Foreground="{DynamicResource HeaderForeground}"
                                  Background="Transparent"
                                  BorderBrush="{DynamicResource BorderBrush}"
                                  Padding="12,6"
                                  Margin="0,0,12,0"
                                  ToolTip="Показать / скрыть дополнительную панель"/>
                    <Border Background="{DynamicResource AccentLight}"
                            CornerRadius="14" Padding="10,4">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="Продуктивность"
                                       Foreground="{DynamicResource AccentDark}"
                                       VerticalAlignment="Center"
                                       FontSize="12" Margin="0,0,8,0"/>
                            <RepeatButton Content="−" Click="RepeatDown_Click"
                                          Width="28" Height="24"
                                          Background="{DynamicResource SurfaceBackground}"
                                          Foreground="{DynamicResource TextPrimary}"
                                          BorderBrush="{DynamicResource BorderBrush}"
                                          FontWeight="Bold"
                                          Margin="0,0,4,0"/>
                            <RepeatButton Content="+" Click="RepeatUp_Click"
                                          Width="28" Height="24"
                                          Background="{DynamicResource SurfaceBackground}"
                                          Foreground="{DynamicResource TextPrimary}"
                                          BorderBrush="{DynamicResource BorderBrush}"
                                          FontWeight="Bold"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- НИЖНЯЯ СТРОКА СОСТОЯНИЯ -->
        <Border DockPanel.Dock="Bottom"
                Background="{DynamicResource PanelBackground}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="0,1,0,0"
                Padding="18,6">
            <StatusBar Background="Transparent" Height="26">
                <StatusBar.ItemsPanel>
                    <ItemsPanelTemplate>
                        <StackPanel Orientation="Horizontal"/>
                    </ItemsPanelTemplate>
                </StatusBar.ItemsPanel>
                <StatusBarItem>
                    <StackPanel Orientation="Horizontal">
                        <Ellipse Width="8" Height="8"
                                 Fill="{DynamicResource Accent}"
                                 VerticalAlignment="Center"
                                 Margin="0,0,8,0"/>
                        <TextBlock x:Name="statusText" Text="Готово | Привычек: 0"
                                   Foreground="{DynamicResource TextPrimary}"/>
                    </StackPanel>
                </StatusBarItem>
                <StatusBarItem Margin="20,0,0,0">
                    <TextBlock Foreground="{DynamicResource TextSecondary}">
                        <Run Text="Дата:"/>
                        <Run x:Name="statusDate" FontWeight="SemiBold"
                             Foreground="{DynamicResource TextPrimary}"/>
                    </TextBlock>
                </StatusBarItem>
                <StatusBarItem Margin="20,0,0,0">
                    <TextBlock Foreground="{DynamicResource TextSecondary}">
                        <Run Text="Пользователь:"/>
                        <Run x:Name="statusUser" Text="не задан"
                             FontWeight="SemiBold"
                             Foreground="{DynamicResource TextPrimary}"/>
                    </TextBlock>
                </StatusBarItem>
            </StatusBar>
        </Border>

        <!-- ОСНОВНОЙ КОНТЕНТ: TabControl с боковой панелью -->
        <TabControl x:Name="mainTabControl"
                    TabStripPlacement="Left"
                    SelectionChanged="MainTabControl_SelectionChanged"
                    Background="{DynamicResource WindowBackground}"
                    BorderThickness="0"
                    Padding="0">

            <TabControl.Resources>
                <Style TargetType="TabPanel">
                    <Setter Property="Background" Value="{DynamicResource PanelBackground}"/>
                </Style>
            </TabControl.Resources>

            <!-- ВКЛАДКА 1: ЛИЧНЫЕ ДАННЫЕ -->
            <TabItem Header="◐  Личные данные">
                <Border Padding="22" Background="{DynamicResource WindowBackground}">
                    <DockPanel>

                        <!-- Скрытая боковая панель -->
                        <Border x:Name="extraPanel"
                                DockPanel.Dock="Right"
                                Visibility="Collapsed"
                                Width="240"
                                Style="{StaticResource CardBorder}"
                                Margin="14,0,0,0">
                            <StackPanel>
                                <TextBlock Style="{StaticResource CardTitle}"
                                           Text="Дополнительно"/>
                                <Label Content="НИК"/>
                                <TextBox x:Name="txtNickname" Margin="0,0,0,10"/>
                                <Label Content="ЦЕЛЬ НА МЕСЯЦ"/>
                                <TextBox x:Name="txtGoal" Height="90"
                                         TextWrapping="Wrap"
                                         AcceptsReturn="True"
                                         VerticalContentAlignment="Top"/>
                            </StackPanel>
                        </Border>

                        <ScrollViewer VerticalScrollBarVisibility="Auto"
                                      HorizontalScrollBarVisibility="Disabled">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="2*" MinWidth="320"/>
                                    <ColumnDefinition Width="14"/>
                                    <ColumnDefinition Width="3*" MinWidth="380"/>
                                </Grid.ColumnDefinitions>

                                <!-- Левая колонка: аватар + кнопки управления -->
                                <StackPanel Grid.Column="0">
                                    <Border Style="{StaticResource CardBorder}">
                                        <StackPanel HorizontalAlignment="Center">
                                            <Border BorderBrush="{DynamicResource Accent}"
                                                    BorderThickness="3"
                                                    CornerRadius="20"
                                                    Width="150" Height="150"
                                                    Background="{DynamicResource AccentLight}"
                                                    ClipToBounds="True">
                                                <Image x:Name="imgAvatar"
                                                       Stretch="UniformToFill"/>
                                            </Border>
                                            <Button Content="Загрузить фото"
                                                    Click="LoadAvatar_Click"
                                                    Style="{StaticResource GhostButton}"
                                                    Margin="0,16,0,0"
                                                    HorizontalAlignment="Center"/>
                                            <TextBlock Text="PNG / JPG / BMP"
                                                       Foreground="{DynamicResource TextSecondary}"
                                                       FontSize="11"
                                                       HorizontalAlignment="Center"
                                                       Margin="0,6,0,0"/>
                                        </StackPanel>
                                    </Border>

                                    <Border Style="{StaticResource CardBorder}">
                                        <StackPanel>
                                            <TextBlock Style="{StaticResource CardTitle}"
                                                       Text="Настройки"/>
                                            <CheckBox x:Name="chkNotifications"
                                                      Content="Получать уведомления"/>
                                            <CheckBox x:Name="chkPublicStats"
                                                      Content="Показывать статистику публично"/>
                                            <CheckBox x:Name="chkAutoSave"
                                                      Content="Автосохранение"
                                                      IsChecked="True"/>
                                            <CheckBox x:Name="chkDarkMode"
                                                      Content="Тёмный режим"
                                                      Checked="ChkDarkMode_Checked"
                                                      Unchecked="ChkDarkMode_Unchecked"/>
                                        </StackPanel>
                                    </Border>

                                    <Border Style="{StaticResource CardBorder}">
                                        <StackPanel>
                                            <StackPanel Orientation="Horizontal">
                                                <Button Content="Сохранить"
                                                        Click="SaveProfile_Click"
                                                        Margin="0,0,10,0"/>
                                                <Button Content="Сбросить"
                                                        Click="ResetProfile_Click"
                                                        Style="{StaticResource DangerButton}"/>
                                            </StackPanel>
                                            <TextBlock x:Name="lblValidation"
                                                       TextWrapping="Wrap"
                                                       Margin="0,10,0,0"
                                                       FontSize="12"
                                                       Foreground="{DynamicResource Danger}"/>
                                        </StackPanel>
                                    </Border>
                                </StackPanel>

                                <!-- Правая колонка: поля ввода -->
                                <StackPanel Grid.Column="2">
                                    <Border Style="{StaticResource CardBorder}">
                                        <StackPanel>
                                            <TextBlock Style="{StaticResource CardTitle}"
                                                       Text="Основная информация"/>
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="14"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                <StackPanel Grid.Column="0">
                                                    <Label Content="ИМЯ"/>
                                                    <TextBox x:Name="txtFirstName"/>
                                                </StackPanel>
                                                <StackPanel Grid.Column="2">
                                                    <Label Content="ФАМИЛИЯ"/>
                                                    <TextBox x:Name="txtLastName"/>
                                                </StackPanel>
                                            </Grid>
                                            <Grid Margin="0,12,0,0">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="14"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                <StackPanel Grid.Column="0">
                                                    <Label Content="ПАРОЛЬ"/>
                                                    <PasswordBox x:Name="pwdPassword"/>
                                                </StackPanel>
                                                <StackPanel Grid.Column="2">
                                                    <Label Content="ДАТА РОЖДЕНИЯ"/>
                                                    <DatePicker x:Name="dtpBirthDate"
                                                                Padding="6"/>
                                                </StackPanel>
                                            </Grid>
                                        </StackPanel>
                                    </Border>

                                    <Border Style="{StaticResource CardBorder}">
                                        <StackPanel>
                                            <TextBlock Style="{StaticResource CardTitle}"
                                                       Text="Дополнительные данные"/>
                                            <Label Content="ОБРАЗОВАНИЕ"/>
                                            <ComboBox x:Name="cmbEducation" Margin="0,0,0,12">
                                                <ComboBoxItem Content="Среднее"/>
                                                <ComboBoxItem Content="Среднее специальное"/>
                                                <ComboBoxItem Content="Высшее"/>
                                                <ComboBoxItem Content="Аспирантура"/>
                                            </ComboBox>

                                            <Label Content="ХОББИ (МНОЖЕСТВЕННЫЙ ВЫБОР)"/>
                                            <ListBox x:Name="lstHobbies"
                                                     SelectionMode="Multiple"
                                                     Height="118"
                                                     Margin="0,0,0,12">
                                                <ListBoxItem Content="Спорт"/>
                                                <ListBoxItem Content="Чтение"/>
                                                <ListBoxItem Content="Музыка"/>
                                                <ListBoxItem Content="Программирование"/>
                                                <ListBoxItem Content="Путешествия"/>
                                            </ListBox>

                                            <Label Content="УРОВЕНЬ АКТИВНОСТИ"/>
                                            <WrapPanel Margin="0,4,0,0">
                                                <RadioButton x:Name="rbLow"
                                                             Content="Низкий"
                                                             GroupName="ActivityLevel"/>
                                                <RadioButton x:Name="rbMedium"
                                                             Content="Средний"
                                                             GroupName="ActivityLevel"
                                                             IsChecked="True"/>
                                                <RadioButton x:Name="rbHigh"
                                                             Content="Высокий"
                                                             GroupName="ActivityLevel"/>
                                            </WrapPanel>
                                        </StackPanel>
                                    </Border>
                                </StackPanel>
                            </Grid>
                        </ScrollViewer>
                    </DockPanel>
                </Border>
            </TabItem>

            <!-- ВКЛАДКА 2: ПРИВЫЧКИ -->
            <TabItem Header="◑  Привычки">
                <Border Padding="22" Background="{DynamicResource WindowBackground}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="3*" MinWidth="380"/>
                            <ColumnDefinition Width="14"/>
                            <ColumnDefinition Width="2*" MinWidth="300"/>
                        </Grid.ColumnDefinitions>

                        <!-- Левая колонка: таблица + добавление -->
                        <StackPanel Grid.Column="0">

                            <Border Style="{StaticResource CardBorder}">
                                <StackPanel>
                                    <TextBlock Style="{StaticResource CardTitle}"
                                               Text="Мои привычки"/>
                                    <DataGrid x:Name="dgHabits"
                                              AutoGenerateColumns="False"
                                              CanUserAddRows="False"
                                              CanUserDeleteRows="False"
                                              ItemsSource="{Binding Habits}"
                                              GridLinesVisibility="Horizontal"
                                              HeadersVisibility="Column"
                                              Background="Transparent"
                                              RowBackground="Transparent"
                                              AlternatingRowBackground="{DynamicResource PanelBackground}"
                                              BorderThickness="0"
                                              Height="240"
                                              CellEditEnding="DgHabits_CellEditEnding">
                                        <DataGrid.Columns>
                                            <DataGridTextColumn Header="Привычка"
                                                                Binding="{Binding Name}"
                                                                Width="*"/>
                                            <DataGridTextColumn Header="Время"
                                                                Binding="{Binding Time}"
                                                                Width="90"/>
                                            <DataGridCheckBoxColumn Header="Готово"
                                                                    Binding="{Binding IsCompleted}"
                                                                    Width="80"/>
                                        </DataGrid.Columns>
                                    </DataGrid>
                                </StackPanel>
                            </Border>

                            <Border Style="{StaticResource CardBorder}">
                                <StackPanel>
                                    <TextBlock Style="{StaticResource CardTitle}"
                                               Text="Добавить привычку"/>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="10"/>
                                            <ColumnDefinition Width="110"/>
                                            <ColumnDefinition Width="10"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0">
                                            <Label Content="НАЗВАНИЕ"/>
                                            <TextBox x:Name="txtHabitName"/>
                                        </StackPanel>
                                        <StackPanel Grid.Column="2">
                                            <Label Content="ВРЕМЯ"/>
                                            <TextBox x:Name="txtHabitTime"/>
                                        </StackPanel>
                                        <Button x:Name="btnAddHabit"
                                                Grid.Column="4"
                                                Content="Добавить"
                                                Click="AddHabit_Click"
                                                VerticalAlignment="Bottom"/>
                                    </Grid>
                                    <TextBlock Text="Формат времени: чч:мм"
                                               FontSize="11"
                                               Foreground="{DynamicResource TextSecondary}"
                                               Margin="0,8,0,0"/>
                                </StackPanel>
                            </Border>

                            <Border Style="{StaticResource CardBorder}">
                                <StackPanel>
                                    <TextBlock Style="{StaticResource CardTitle}"
                                               Text="Заметки"/>
                                    <Border BorderBrush="{DynamicResource BorderBrush}"
                                            BorderThickness="1"
                                            CornerRadius="10"
                                            Background="{DynamicResource SurfaceBackground}">
                                        <RichTextBox x:Name="rtbNotes"
                                                     Height="120" Padding="8"
                                                     BorderThickness="0"
                                                     Background="Transparent"/>
                                    </Border>
                                </StackPanel>
                            </Border>
                        </StackPanel>

                        <!-- Правая колонка: календарь + слайдеры -->
                        <StackPanel Grid.Column="2">
                            <Border Style="{StaticResource CardBorder}">
                                <StackPanel>
                                    <TextBlock Style="{StaticResource CardTitle}"
                                               Text="Календарь"/>
                                    <Calendar x:Name="calendar"
                                              SelectedDate="{x:Static system:DateTime.Today}"
                                              SelectedDatesChanged="Calendar_SelectedDatesChanged"
                                              HorizontalAlignment="Center"/>
                                </StackPanel>
                            </Border>

                            <Border Style="{StaticResource CardBorder}">
                                <StackPanel>
                                    <TextBlock Style="{StaticResource CardTitle}"
                                               Text="Показатели дня"/>

                                    <DockPanel Margin="0,0,0,6">
                                        <TextBlock Text="Продуктивность"
                                                   FontWeight="SemiBold"/>
                                        <TextBlock x:Name="lblProductivity"
                                                   DockPanel.Dock="Right"
                                                   Text="50%"
                                                   Foreground="{DynamicResource AccentDark}"
                                                   FontWeight="SemiBold"
                                                   HorizontalAlignment="Right"/>
                                    </DockPanel>
                                    <Slider x:Name="slProductivity"
                                            Minimum="0" Maximum="100" Value="50"
                                            ValueChanged="SlProductivity_ValueChanged"
                                            Margin="0,0,0,14"/>

                                    <DockPanel Margin="0,0,0,6">
                                        <TextBlock Text="Удовлетворённость"
                                                   FontWeight="SemiBold"/>
                                        <TextBlock x:Name="lblSatisfaction"
                                                   DockPanel.Dock="Right"
                                                   Text="50%"
                                                   Foreground="{DynamicResource AccentDark}"
                                                   FontWeight="SemiBold"
                                                   HorizontalAlignment="Right"/>
                                    </DockPanel>
                                    <Slider x:Name="slSatisfaction"
                                            Minimum="0" Maximum="100" Value="50"
                                            ValueChanged="SlSatisfaction_ValueChanged"
                                            Margin="0,0,0,18"/>

                                    <TextBlock Text="Прогресс дня"
                                               FontWeight="SemiBold"
                                               Margin="0,0,0,6"/>
                                    <ProgressBar x:Name="pbDayProgress"
                                                 Minimum="0" Maximum="100" Value="50"
                                                 Height="14"/>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Grid>
                </Border>
            </TabItem>

            <!-- ВКЛАДКА 3: СТАТИСТИКА -->
            <TabItem Header="◓  Статистика">
                <Border Padding="22" Background="{DynamicResource WindowBackground}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="2*" MinWidth="260"/>
                            <ColumnDefinition Width="14"/>
                            <ColumnDefinition Width="3*" MinWidth="380"/>
                        </Grid.ColumnDefinitions>

                        <!-- Левая колонка: дерево категорий -->
                        <Border Grid.Column="0" Style="{StaticResource CardBorder}">
                            <DockPanel>
                                <TextBlock DockPanel.Dock="Top"
                                           Style="{StaticResource CardTitle}"
                                           Text="Категории привычек"/>
                                <TreeView x:Name="tvCategories"
                                          BorderThickness="0"
                                          Background="Transparent">
                                    <TreeViewItem Header="❀  Здоровье" IsExpanded="True">
                                        <TreeViewItem Header="Спорт"/>
                                        <TreeViewItem Header="Правильное питание"/>
                                        <TreeViewItem Header="Здоровый сон"/>
                                    </TreeViewItem>
                                    <TreeViewItem Header="❀  Развитие" IsExpanded="True">
                                        <TreeViewItem Header="Чтение"/>
                                        <TreeViewItem Header="Обучение"/>
                                        <TreeViewItem Header="Медитация"/>
                                    </TreeViewItem>
                                    <TreeViewItem Header="❀  Работа">
                                        <TreeViewItem Header="Планирование задач"/>
                                        <TreeViewItem Header="Фокус-сессии"/>
                                        <TreeViewItem Header="Ревью прогресса"/>
                                    </TreeViewItem>
                                    <TreeViewItem Header="❀  Социальное">
                                        <TreeViewItem Header="Общение с близкими"/>
                                        <TreeViewItem Header="Волонтёрство"/>
                                    </TreeViewItem>
                                </TreeView>
                            </DockPanel>
                        </Border>

                        <!-- Правая колонка: журнал по дням -->
                        <Border Grid.Column="2" Style="{StaticResource CardBorder}">
                            <DockPanel>
                                <TextBlock DockPanel.Dock="Top"
                                           Style="{StaticResource CardTitle}"
                                           Text="История активности"/>
                                <ListView x:Name="lvStatistics"
                                          BorderThickness="0"
                                          Background="Transparent">
                                    <ListView.View>
                                        <GridView>
                                            <GridViewColumn Header="Дата"
                                                            DisplayMemberBinding="{Binding Date, StringFormat=dd.MM.yyyy}"
                                                            Width="100"/>
                                            <GridViewColumn Header="Прод.%"
                                                            DisplayMemberBinding="{Binding Productivity}"
                                                            Width="72"/>
                                            <GridViewColumn Header="Удов.%"
                                                            DisplayMemberBinding="{Binding Satisfaction}"
                                                            Width="72"/>
                                            <GridViewColumn Header="Привычек"
                                                            DisplayMemberBinding="{Binding CompletedHabits}"
                                                            Width="80"/>
                                            <GridViewColumn Header="Прогресс"
                                                            DisplayMemberBinding="{Binding Progress}"
                                                            Width="80"/>
                                        </GridView>
                                    </ListView.View>
                                </ListView>
                            </DockPanel>
                        </Border>
                    </Grid>
                </Border>
            </TabItem>

        </TabControl>
    </DockPanel>
</Window>
