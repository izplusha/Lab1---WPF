<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <SolidColorBrush x:Key="WindowBackground" Color="#1F1D1A"/>
    <SolidColorBrush x:Key="SurfaceBackground" Color="#2A2824"/>
    <SolidColorBrush x:Key="PanelBackground"   Color="#262420"/>
    <SolidColorBrush x:Key="HeaderBackground"  Color="#15201A"/>
    <SolidColorBrush x:Key="HeaderForeground"  Color="#D8E2D2"/>
    <SolidColorBrush x:Key="TextPrimary"       Color="#EDE7D8"/>
    <SolidColorBrush x:Key="TextSecondary"     Color="#A89F8E"/>
    <SolidColorBrush x:Key="Accent"            Color="#8FAF85"/>
    <SolidColorBrush x:Key="AccentDark"        Color="#6B8E5A"/>
    <SolidColorBrush x:Key="AccentLight"       Color="#3A4A36"/>
    <SolidColorBrush x:Key="Danger"            Color="#C97E7E"/>
    <SolidColorBrush x:Key="BorderBrush"       Color="#3D3A33"/>

</ResourceDictionary>
